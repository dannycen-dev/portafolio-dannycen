---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";
---

<BaseLayout
  title={`Proyectos — ${site.name}`}
  description="Proyectos de desarrollo web, automatización e inteligencia artificial."
>
  <section class="section">
    <div class="container">
      <div data-reveal>
        <p class="section-label">Proyectos</p>
        <h1 class="section-title">Selección de trabajo</h1>
        <p class="section-lead">
          Casos donde mezclé desarrollo, IA y automatización para generar resultados
          medibles.
        </p>
      </div>

      <ul class="list">
        {
          projects.map((project) => (
            <li class="list__item" id={project.slug} data-reveal>
              <div class="list__media" style={`--accent:${project.accent}`}>
                <span>{project.title.slice(0, 2)}</span>
              </div>
              <div class="list__body">
                <p class="list__role">{project.role}</p>
                <h2>{project.title}</h2>
                <p>{project.summary}</p>
                <ul class="list__tags">
                  {project.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .list {
    margin-top: clamp(2rem, 5vw, 3rem);
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
  }

  .list__item {
    display: grid;
    gap: 1.25rem;
    scroll-margin-top: calc(var(--nav-h) + 1rem);
  }

  .list__media {
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(circle at 75% 20%, rgba(255, 255, 255, 0.18), transparent 40%),
      linear-gradient(145deg, color-mix(in srgb, var(--accent) 75%, white), var(--accent));
  }

  .list__media span {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    color: rgba(255, 255, 255, 0.92);
  }

  .list__role {
    margin-bottom: 0.35rem;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .list__body h2 {
    font-size: clamp(1.6rem, 1.2rem + 1.2vw, 2.2rem);
  }

  .list__body p {
    margin-top: 0.6rem;
    max-width: 54ch;
    color: var(--ink-soft);
  }

  .list__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
    margin-top: 1rem;
  }

  .list__tags li {
    font-size: 0.85rem;
    color: var(--accent-deep);
  }

  @media (min-width: 900px) {
    .list__item {
      grid-template-columns: minmax(16rem, 24rem) 1fr;
      align-items: center;
      gap: 2.5rem;
    }
  }
</style>
