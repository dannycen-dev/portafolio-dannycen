---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featuredProjects } from "../data/projects";
import { services, site } from "../data/site";
---

<BaseLayout>
  <Hero />

  <section class="section projects">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="section-label">Proyectos destacados</p>
        <h2 class="section-title">Trabajo que genera impacto real</h2>
        <p class="section-lead">
          De agentes conversacionales a sistemas empresariales: soluciones pensadas
          para ahorrar tiempo, convertir más y escalar operaciones.
        </p>
      </div>

      <div class="projects__grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>

      <p class="projects__more" data-reveal>
        <a class="link-arrow" href="/projects">
          Ver todos los proyectos
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 5l7 7-7 7"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </p>
    </div>
  </section>

  <section class="section services">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="section-label">Servicios freelance</p>
        <h2 class="section-title">Cómo puedo ayudarte</h2>
        <p class="section-lead">
          Perfil híbrido técnico–estratégico: desarrollo, automatización e IA con
          mirada de producto y operación.
        </p>
      </div>

      <ul class="services__list">
        {
          services.map((service, i) => (
            <li class="services__item" data-reveal>
              <span class="services__index">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section cta">
    <div class="container cta__inner" data-reveal>
      <p class="section-label">Disponible para colaborar</p>
      <h2 class="section-title">¿Listo para automatizar o construir tu siguiente producto?</h2>
      <p class="section-lead">{site.availability}</p>
      <div class="cta__actions">
        <a class="btn" href={`mailto:${site.email}`}>Escribirme</a>
        <a class="btn btn--ghost" href="/contact">Ver contacto</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .projects__grid {
    display: grid;
    gap: clamp(1.75rem, 4vw, 2.5rem);
    margin-top: clamp(2rem, 5vw, 3rem);
  }

  .projects__more {
    margin-top: 2rem;
  }

  .services {
    border-block: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
  }

  .services__list {
    margin-top: clamp(2rem, 5vw, 3rem);
    display: grid;
  }

  .services__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .services__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .services__index {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--accent);
  }

  .services__item h3 {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }

  .services__item p {
    max-width: 52ch;
    color: var(--ink-soft);
  }

  .cta__inner {
    max-width: 42rem;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  @media (min-width: 780px) {
    .projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .services__item {
      gap: 1.5rem;
      padding-block: 1.75rem;
    }
  }
</style>
