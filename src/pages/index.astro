---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PortfolioCarousel from "../components/PortfolioCarousel.astro";
import BlogCarousel from "../components/BlogCarousel.astro";
import ContactActions from "../components/ContactActions.astro";
import { getLangFromUrl, localePath } from "../i18n/utils";
import { localizedSite, servicesByLang } from "../i18n/content";
import { useTranslations } from "../i18n/ui";
import { getPortfolio } from "../i18n/portfolio";
import { getRecentBlogPosts } from "../i18n/blog";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const loc = localizedSite(lang);
const services = servicesByLang[lang];
const featuredProjects = (await getPortfolio(lang)).filter((p) => p.data.featured);
const recentPosts = await getRecentBlogPosts(lang, 6);
---

<BaseLayout>
  <Hero />

  <section class="section projects">
    <div class="container">
      <div class="section-head">
        <p class="section-label">{t("home.featured_label")}</p>
        <h2 class="section-title">{t("home.featured_title")}</h2>
        <p class="section-lead">{t("home.featured_lead")}</p>
      </div>

      {
        featuredProjects.length > 0 ? (
          <PortfolioCarousel projects={featuredProjects} lang={lang} />
        ) : null
      }

      <p class="section__more">
        <a class="link-arrow" href={localePath(lang, "portafolio")}>
          {t("home.featured_more")}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 5l7 7-7 7"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </p>
    </div>
  </section>

  <section class="section blog-home">
    <div class="container">
      <div class="section-head">
        <p class="section-label">{t("home.blog_label")}</p>
        <h2 class="section-title">{t("home.blog_title")}</h2>
        <p class="section-lead">{t("home.blog_lead")}</p>
      </div>

      {recentPosts.length > 0 ? <BlogCarousel posts={recentPosts} lang={lang} /> : null}

      <p class="section__more">
        <a class="link-arrow" href={localePath(lang, "blog")}>
          {t("home.blog_more")}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 5l7 7-7 7"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </p>
    </div>
  </section>

  <section class="section services">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="section-label">{t("home.services_label")}</p>
        <h2 class="section-title">{t("home.services_title")}</h2>
        <p class="section-lead">{t("home.services_lead")}</p>
      </div>

      <ul class="services__list">
        {
          services.map((service, i) => (
            <li class="services__item" data-reveal>
              <span class="services__index">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section cta">
    <div class="container cta__inner" data-reveal>
      <p class="section-label">{t("home.cta_label")}</p>
      <h2 class="section-title">{t("home.cta_title")}</h2>
      <p class="section-lead">{loc.availability}</p>
      <div class="cta__actions">
        <button class="btn" type="button" data-modal-open="message">
          {t("home.cta_email")}
        </button>
        <a class="btn btn--ghost" href={localePath(lang, "contact")}>{t("home.cta_contact")}</a>
      </div>
    </div>
  </section>

  <ContactActions lang={lang} showTriggers={false} />
</BaseLayout>

<style>
  .section__more {
    margin-top: 2rem;
  }

  .blog-home {
    border-top: 1px solid var(--line);
  }

  .services {
    border-block: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
  }

  .services__list {
    margin-top: clamp(2rem, 5vw, 3rem);
    display: grid;
  }

  .services__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .services__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .services__index {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--accent-deep);
  }

  .services__item h3 {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }

  .services__item p {
    max-width: 52ch;
    color: var(--ink-soft);
  }

  .cta__inner {
    max-width: 42rem;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  @media (min-width: 780px) {
    .services__item {
      gap: 1.5rem;
      padding-block: 1.75rem;
    }
  }
</style>
