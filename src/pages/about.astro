---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { getLangFromUrl } from "../i18n/utils";
import { experienceByLang, localizedSite, skillsByLang } from "../i18n/content";
import { useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const loc = localizedSite(lang);
const experience = experienceByLang[lang];
const skills = skillsByLang[lang];
---

<BaseLayout title={`${t("about.label")} — ${site.name}`} description={loc.shortBio}>
  <section class="section about">
    <div class="container about__grid">
      <div data-reveal>
        <p class="section-label">{t("about.label")}</p>
        <h1 class="section-title">{t("about.title")}</h1>
      </div>
      <div class="about__copy" data-reveal>
        <p>
          {t("about.p1", { name: site.name, location: loc.location })}
        </p>
        <p>{t("about.p2")}</p>
        <p>{t("about.p3")}</p>
      </div>
    </div>
  </section>

  <section class="section experience">
    <div class="container">
      <div data-reveal>
        <p class="section-label">{t("about.exp_label")}</p>
        <h2 class="section-title">{t("about.exp_title")}</h2>
      </div>
      <ol class="timeline">
        {
          experience.map((job) => (
            <li class="timeline__item" data-reveal>
              <div class="timeline__meta">
                <p class="timeline__period">{job.period}</p>
                <p class="timeline__mode">{job.mode}</p>
              </div>
              <div>
                <h3>{job.role}</h3>
                <p class="timeline__company">{job.company}</p>
                <p>{job.summary}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section skills">
    <div class="container">
      <div data-reveal>
        <p class="section-label">{t("about.stack_label")}</p>
        <h2 class="section-title">{t("about.stack_title")}</h2>
      </div>
      <div class="skills__grid">
        {
          Object.entries(skills).map(([group, items]) => (
            <div class="skills__group" data-reveal>
              <h3>{group}</h3>
              <ul>
                {items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about__grid {
    display: grid;
    gap: 1.75rem;
  }

  .about__copy {
    display: grid;
    gap: 1rem;
    max-width: 58ch;
    color: var(--ink-soft);
  }

  .experience {
    border-block: 1px solid var(--line);
  }

  .timeline {
    margin-top: 2.5rem;
    display: grid;
    gap: 0;
  }

  .timeline__item {
    display: grid;
    gap: 0.75rem;
    padding-block: 1.6rem;
    border-top: 1px solid var(--line);
  }

  .timeline__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .timeline__period {
    font-family: var(--font-display);
    font-weight: 650;
  }

  .timeline__mode,
  .timeline__company {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .timeline__company {
    margin-block: 0.25rem 0.55rem;
    color: var(--accent);
    font-weight: 600;
  }

  .timeline h3 {
    font-size: 1.35rem;
  }

  .timeline__item p:last-child {
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .skills__grid {
    display: grid;
    gap: 1.75rem;
    margin-top: 2.5rem;
  }

  .skills__group h3 {
    margin-bottom: 0.85rem;
    font-size: 1.15rem;
  }

  .skills__group ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
  }

  .skills__group li {
    color: var(--ink-soft);
    border-bottom: 1px solid var(--line);
  }

  @media (min-width: 860px) {
    .about__grid {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: start;
      gap: 3rem;
    }

    .timeline__item {
      grid-template-columns: 14rem 1fr;
      gap: 2rem;
    }

    .skills__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }
  }
</style>
