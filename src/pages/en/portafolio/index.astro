---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { site } from "../../../data/site";
import { getLangFromUrl, localePath, portfolioSlug } from "../../../i18n/utils";
import { useTranslations } from "../../../i18n/ui";
import { getPortfolio } from "../../../i18n/portfolio";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const entries = await getPortfolio(lang);
---

<BaseLayout title={`${t("portfolio.label")} — ${site.name}`} description={t("portfolio.meta_description")}>
  <section class="section">
    <div class="container">
      <div class="index__intro">
        <p class="section-label">{t("portfolio.label")}</p>
        <h1 class="section-title">{t("portfolio.title")}</h1>
        <p class="section-lead">
          {t("portfolio.lead")}
        </p>
      </div>

      <ul class="index">
        {
          entries.map((entry, i) => {
            const slug = portfolioSlug(entry.id);
            return (
              <li class="index__item">
                <a class="index__link" href={localePath(lang, `portafolio/${slug}`)}>
                  <div class="index__media" style={`--accent:${entry.data.accent}`}>
                    <img
                      src={entry.data.cover}
                      alt={entry.data.title}
                      width="720"
                      height="450"
                      loading={i < 2 ? "eager" : "lazy"}
                    />
                  </div>
                  <div class="index__body">
                    <p class="index__role">{entry.data.role}</p>
                    <h2>{entry.data.title}</h2>
                    <p>{entry.data.summary}</p>
                    <ul class="index__tags">
                      {entry.data.tags.map((tag) => (
                        <li>{tag}</li>
                      ))}
                    </ul>
                  </div>
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .index__intro {
    max-width: 52rem;
  }

  .index {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.15rem;
    margin-top: clamp(2rem, 5vw, 3rem);
    list-style: none;
    padding: 0;
    margin-inline: 0;
  }

  .index__item {
    display: block;
    min-width: 0;
  }

  .index__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    transition: border-color 0.28s var(--ease-out);
  }

  .index__link:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--line));
  }

  .index__media {
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: color-mix(in srgb, var(--accent) 40%, var(--bg));
    border-bottom: 1px solid var(--line);
  }

  .index__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.55s var(--ease-out);
  }

  .index__link:hover .index__media img {
    transform: scale(1.03);
  }

  .index__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: clamp(1rem, 2.2vw, 1.35rem);
  }

  .index__role {
    margin-bottom: 0.4rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .index__body h2 {
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.45rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .index__body > p {
    margin-top: 0.5rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
    flex: 1;
  }

  .index__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
    margin-top: 0.9rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--line);
  }

  .index__tags li {
    font-size: 0.78rem;
    color: var(--accent-deep);
  }

  @media (min-width: 640px) {
    .index {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .index {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.35rem;
    }
  }
</style>
