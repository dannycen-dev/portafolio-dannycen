---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SiteLoader from "../components/SiteLoader.astro";
import { site } from "../data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.title}`,
  description = site.shortBio,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://dannycen.dev");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content={site.fullName} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Saltar al contenido</a>
    <SiteLoader />
    <Header />
    <main id="main" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/animations.ts";
    </script>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    left: var(--gutter);
    top: -4rem;
    z-index: 100;
    padding: 0.75rem 1rem;
    background: var(--ink);
    color: white;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 1rem;
  }
</style>
