---
import { site, nav } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand" data-reveal>
      <a href="/" class="footer__name">{site.name} ↴</a>
      <p>{site.title}</p>
      <p class="footer__loc">{site.location}</p>
    </div>

    <div class="footer__cols">
      <div data-reveal>
        <h3>Páginas</h3>
        <ul>
          {nav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div data-reveal>
        <h3>Contacto</h3>
        <ul>
          <li>
            <a href={`mailto:${site.email}`}>Email</a>
          </li>
          <li>
            <a href={site.linkedin} target="_blank" rel="noopener noreferrer">
              LinkedIn
            </a>
          </li>
          <li>
            <a href={site.github} target="_blank" rel="noopener noreferrer">
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <p class="footer__copy">© {year} {site.fullName}</p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--line);
    padding-block: clamp(3rem, 8vw, 5rem) 2rem;
  }

  .footer__inner {
    display: grid;
    gap: 2.5rem;
  }

  .footer__name {
    display: inline-block;
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-decoration: none;
  }

  .footer__brand p {
    max-width: 34ch;
    color: var(--ink-soft);
  }

  .footer__loc {
    margin-top: 0.5rem;
    color: var(--muted);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 12rem));
    gap: 2rem;
  }

  .footer h3 {
    margin-bottom: 0.85rem;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .footer ul {
    display: grid;
    gap: 0.55rem;
  }

  .footer a {
    text-decoration: none;
  }

  .footer__copy {
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media (min-width: 900px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }

    .footer__copy {
      grid-column: 1 / -1;
    }
  }
</style>
