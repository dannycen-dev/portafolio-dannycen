---
import { site } from "../data/site";
---

<div
  class="loader"
  data-loader
  hidden
  aria-hidden="true"
  aria-live="polite"
>
  <div class="loader__inner">
    <p class="loader__mark" data-loader-mark aria-hidden="true">
      <span>D</span><span>C</span>
    </p>
    <p class="loader__name">{site.name}</p>
    <div class="loader__progress" aria-hidden="true">
      <span class="loader__bar" data-loader-bar></span>
    </div>
  </div>
</div>

<style>
  .loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    place-items: center;
    background: #07131a;
    color: #f4efe4;
  }

  .loader.is-active {
    display: grid;
  }

  .loader.is-done {
    pointer-events: none;
  }

  .loader__inner {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    width: min(14rem, 70vw);
  }

  .loader__mark {
    display: flex;
    overflow: hidden;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 10vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .loader__mark span {
    display: inline-block;
  }

  .loader__name {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(244, 239, 228, 0.55);
  }

  .loader__progress {
    width: 100%;
    height: 1px;
    overflow: hidden;
    background: rgba(244, 239, 228, 0.18);
  }

  .loader__bar {
    display: block;
    width: 100%;
    height: 100%;
    background: #c8a45c;
    transform: scaleX(0);
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    .loader {
      display: none !important;
    }
  }
</style>
