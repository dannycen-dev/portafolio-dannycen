---
import { site } from "../data/site";
---

<div class="loader" data-loader aria-live="polite" aria-busy="true">
  <div class="loader__inner">
    <p class="loader__mark" data-loader-mark aria-hidden="true">
      <span>D</span><span>C</span>
    </p>
    <p class="loader__name">{site.name}</p>
    <div class="loader__progress" aria-hidden="true">
      <span class="loader__bar" data-loader-bar></span>
    </div>
  </div>
</div>

<style>
  .loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    background: #121614;
    color: #f4f6f4;
  }

  .loader.is-done {
    pointer-events: none;
  }

  .loader__inner {
    display: grid;
    justify-items: center;
    gap: 1rem;
    width: min(16rem, 70vw);
  }

  .loader__mark {
    display: flex;
    overflow: hidden;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .loader__mark span {
    display: inline-block;
  }

  .loader__name {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(244, 246, 244, 0.55);
  }

  .loader__progress {
    width: 100%;
    height: 1px;
    overflow: hidden;
    background: rgba(244, 246, 244, 0.18);
  }

  .loader__bar {
    display: block;
    width: 100%;
    height: 100%;
    background: #1b6b63;
    transform: scaleX(0);
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    .loader {
      display: none;
    }
  }
</style>
