---
import { site } from "../data/site";
import { localizedSite } from "../i18n/content";
import { useTranslations } from "../i18n/ui";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const loc = localizedSite(lang);
const { booking } = site;
const locale = lang === "en" ? "en-US" : "es-MX";
---

<div
  class="booking"
  data-booking
  data-lang={lang}
  data-locale={locale}
  data-email={site.email}
  data-tz={booking.timezone}
  data-tz-label={booking.timezoneLabel}
  data-via={booking.meetingVia}
  data-subject-tpl={t("booking.mail_subject")}
  data-body-tpl={t("booking.mail_body")}
  data-need-date={t("booking.need_date")}
  data-need-time={t("booking.need_time")}
>
  <div class="booking__layout">
    <aside class="booking__aside">
      <div class="booking__who">
        <div class="booking__avatar" aria-hidden="true">
          <img src={site.profileImage} alt="" width="96" height="96" loading="lazy" decoding="async" />
        </div>
        <div>
          <p class="booking__name">{site.name}</p>
          <p class="booking__role">{loc.title}</p>
        </div>
      </div>

      <p class="booking__meeting">{t("booking.title")}</p>

      <ul class="booking__meta">
        <li>
          <span class="booking__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"></circle><path
                d="M12 7v5l3 2"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"></path></svg
            >
          </span>
          {t("booking.duration", { min: String(booking.durationMin) })}
        </li>
        <li>
          <span class="booking__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><rect x="3" y="7" width="18" height="12" rx="1" stroke="currentColor" stroke-width="1.6"
              ></rect><path
                d="M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"
                stroke="currentColor"
                stroke-width="1.6"></path><path d="M10 13l5 3-5 3v-6z" fill="currentColor"></path></svg
            >
          </span>
          {booking.meetingVia}
        </li>
        <li>
          <span class="booking__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"></circle><path
                d="M3 12h18M12 3c2.5 2.8 3.8 5.8 3.8 9S14.5 18.2 12 21c-2.5-2.8-3.8-5.8-3.8-9S9.5 5.8 12 3z"
                stroke="currentColor"
                stroke-width="1.6"></path></svg
            >
          </span>
          {booking.timezoneLabel}
        </li>
      </ul>

      <p class="booking__copy">{t("booking.lead")}</p>
    </aside>

    <div class="booking__panel">
      <div class="booking__cal">
        <div class="booking__cal-head">
          <h3>{t("booking.select_date")}</h3>
          <div class="booking__nav">
            <button type="button" data-booking-prev aria-label={t("booking.prev_month")}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
                ><path
                  d="M15 6l-6 6 6 6"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </button>
            <button type="button" data-booking-next aria-label={t("booking.next_month")}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
                ><path
                  d="M9 6l6 6-6 6"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </button>
          </div>
        </div>
        <p class="booking__month" data-booking-month></p>
        <div class="booking__weekdays" data-booking-weekdays></div>
        <div class="booking__grid" data-booking-grid role="grid"></div>
      </div>

        <div class="booking__times">
        <div class="booking__times-head">
          <h3>{t("booking.select_time")}</h3>
          <p data-booking-selected-label>{t("booking.need_date")}</p>
        </div>

        <div
          class="booking__reveal"
          data-booking-slots-wrap
          aria-hidden="true"
        >
          <div class="booking__reveal-inner">
            <div class="booking__slots" data-booking-slots></div>
          </div>
        </div>

        <div
          class="booking__reveal booking__reveal--guest"
          data-booking-guest
          aria-hidden="true"
        >
          <div class="booking__reveal-inner">
            <div class="booking__guest">
              <p class="booking__guest-title">{t("booking.your_details")}</p>
              <label>
                <span>{t("booking.guest_name")}</span>
                <input type="text" name="guest-name" data-booking-name autocomplete="name" required />
              </label>
              <label>
                <span>{t("booking.guest_email")}</span>
                <input type="email" name="guest-email" data-booking-email autocomplete="email" required />
              </label>
              <label>
                <span>{t("booking.guest_phone")}</span>
                <input type="tel" name="guest-phone" data-booking-phone autocomplete="tel" required />
              </label>
            </div>
          </div>
        </div>

        <button class="btn booking__confirm" type="button" data-booking-confirm disabled>
          {t("booking.confirm")}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import "../scripts/booking.ts";
</script>

<style>
  .booking__layout {
    display: grid;
    gap: 1rem;
  }

  .booking__aside,
  .booking__panel {
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
  }

  .booking__aside {
    padding: clamp(1.15rem, 2.5vw, 1.5rem);
  }

  .booking__who {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.1rem;
  }

  .booking__avatar {
    width: 3rem;
    height: 3rem;
    overflow: hidden;
    border: 1px solid var(--accent);
    background: var(--accent-soft);
    flex-shrink: 0;
  }

  .booking__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .booking__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }

  .booking__role {
    color: var(--muted);
    font-size: 0.88rem;
  }

  .booking__meeting {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .booking__meta {
    display: grid;
    gap: 0.65rem;
    margin-bottom: 1.1rem;
  }

  .booking__meta li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .booking__icon {
    color: var(--accent);
    display: inline-flex;
  }

  .booking__copy {
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .booking__panel {
    display: grid;
  }

  .booking__cal,
  .booking__times {
    padding: clamp(1.1rem, 2.5vw, 1.4rem);
  }

  .booking__cal {
    border-bottom: 1px solid var(--line);
  }

  .booking__cal-head,
  .booking__times-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .booking__cal-head h3,
  .booking__times-head h3 {
    font-size: 1.05rem;
  }

  .booking__nav {
    display: flex;
    gap: 0.25rem;
  }

  .booking__nav button {
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    display: grid;
    place-items: center;
  }

  .booking__nav button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .booking__month {
    text-align: center;
    font-family: var(--font-display);
    font-weight: 650;
    color: var(--accent-deep);
    margin-bottom: 0.65rem;
  }

  .booking__weekdays,
  .booking__grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.15rem;
  }

  .booking__weekdays span {
    text-align: center;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.3rem 0;
  }

  .booking__grid :global(button) {
    aspect-ratio: 1;
    border: 0;
    background: transparent;
    color: var(--ink);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .booking__grid :global(button:hover:not(:disabled)) {
    background: var(--accent-soft);
  }

  .booking__grid :global(button.is-muted),
  .booking__grid :global(button:disabled) {
    color: color-mix(in srgb, var(--muted) 55%, transparent);
    cursor: default;
  }

  .booking__grid :global(button.is-selected) {
    background: var(--accent);
    color: white;
  }

  .booking__times-head {
    flex-wrap: wrap;
  }

  .booking__times-head p {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    width: 100%;
  }

  .booking__reveal {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transform: translateY(0.35rem);
    transition:
      grid-template-rows 0.36s var(--ease-out),
      opacity 0.28s var(--ease-out),
      transform 0.32s var(--ease-out);
    pointer-events: none;
  }

  .booking__reveal.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .booking__reveal-inner {
    overflow: hidden;
    min-height: 0;
  }

  .booking__slots {
    display: grid;
    gap: 0.5rem;
    max-height: min(14rem, 38vh);
    overflow: auto;
    margin: 0.15rem 0 0.55rem;
    padding-right: 0.1rem;
  }

  .booking__slots :global(button) {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink-soft);
    font-weight: 650;
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    transition:
      border-color 0.2s var(--ease-out),
      color 0.2s var(--ease-out),
      background-color 0.2s var(--ease-out);
  }

  .booking__slots :global(button:hover) {
    border-color: var(--accent);
    color: var(--accent-deep);
  }

  .booking__slots :global(button.is-selected) {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .booking__guest {
    display: grid;
    gap: 0.75rem;
    margin: 0.35rem 0 0.85rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .booking__guest-title {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: 0.98rem;
  }

  .booking__guest label {
    display: grid;
    gap: 0.35rem;
  }

  .booking__guest span {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .booking__guest input {
    width: 100%;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    padding: 0.7rem 0.8rem;
    font: inherit;
  }

  .booking__guest input:focus {
    outline: 2px solid color-mix(in srgb, var(--accent) 45%, transparent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .booking__confirm {
    width: 100%;
    justify-content: center;
    transition: opacity 0.25s var(--ease-out);
  }

  .booking__confirm:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  @media (max-width: 859px) {
    .booking__layout {
      gap: 0.85rem;
    }

    .booking__aside {
      padding: 1rem;
    }

    .booking__role,
    .booking__copy {
      font-size: 0.9rem;
    }

    .booking__cal,
    .booking__times {
      padding: 1rem;
    }

    .booking__grid :global(button) {
      font-size: 0.8rem;
      min-height: 2.4rem;
    }

    .booking__slots {
      max-height: min(12rem, 32vh);
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 860px) {
    .booking__layout {
      grid-template-columns: minmax(13rem, 0.85fr) minmax(0, 1.75fr);
      align-items: stretch;
    }

    .booking__panel {
      grid-template-columns: minmax(0, 1.25fr) minmax(11rem, 0.9fr);
    }

    .booking__cal {
      border-bottom: 0;
      border-right: 1px solid var(--line);
    }

    .booking__times-head p {
      width: auto;
      text-align: right;
    }

    .booking__slots {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 1100px) {
    .booking__layout {
      grid-template-columns: minmax(15rem, 0.9fr) minmax(0, 1.7fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .booking__reveal,
    .booking__confirm,
    .booking__slots :global(button) {
      transition: none;
    }
  }
</style>
