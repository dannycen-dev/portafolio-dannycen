---
import { site } from "../data/site";
import YucatanSky from "./YucatanSky.astro";
import { getLangFromUrl, localePath } from "../i18n/utils";
import { localizedSite } from "../i18n/content";
import { useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const loc = localizedSite(lang);
---

<section class="hero container" data-hero>
  <div class="hero__media" data-hero-image>
    <YucatanSky captionPrimary={t("sky.caption1")} captionSecondary={t("sky.caption2")} />
  </div>

  <div class="hero__copy">
    <p class="hero__eyebrow" data-hero-anim>{loc.location}</p>
    <h1 data-hero-anim>
      {t("hero.h1_before")} <span>{site.name}</span>{t("hero.h1_after")}
    </h1>
    <p class="hero__lead" data-hero-anim>
      {loc.shortBio}
      <a href={localePath(lang, "about")}>{t("hero.about_link")}</a>.
    </p>
    <div class="hero__actions" data-hero-anim>
      <a class="btn" href={localePath(lang, "contact")}>{t("hero.cta_primary")}</a>
      <a class="btn btn--ghost" href={localePath(lang, "portafolio")}>{t("hero.cta_secondary")}</a>
    </div>
    <div class="hero__social" data-hero-anim>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: clamp(2rem, 5vw, 3.5rem) clamp(3rem, 8vw, 5rem);
  }

  .hero__media {
    position: relative;
    overflow: hidden;
    /* Same night gradient as sky — paints before scoped sky CSS to avoid flash */
    background:
      radial-gradient(80% 50% at 50% 78%, rgba(27, 107, 99, 0.4), transparent 62%),
      linear-gradient(180deg, #07131a 0%, #0c2a2f 52%, #123a36 100%);
    width: 100%;
    min-height: min(70vw, 28rem);
    aspect-ratio: 4 / 5;
    max-width: 28rem;
    margin-inline: auto;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero__eyebrow {
    margin-bottom: 1rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-deep);
  }

  .hero h1 {
    font-size: clamp(2.2rem, 1.3rem + 3vw, 3.75rem);
    max-width: 20ch;
    color: var(--ink);
  }

  .hero h1 span {
    color: var(--accent-deep);
  }

  .hero__lead {
    margin-top: 1.25rem;
    max-width: 42ch;
    color: var(--ink-soft);
  }

  .hero__lead a {
    font-weight: 700;
    color: var(--accent-deep);
    text-decoration-thickness: 1.5px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .hero__social {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.75rem;
    font-size: 0.95rem;
  }

  .hero__social a {
    text-decoration: none;
    font-weight: 700;
    color: var(--ink);
  }

  .hero__social a:hover {
    color: var(--accent-deep);
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(20rem, 0.95fr) minmax(0, 1.15fr);
      align-items: stretch;
      gap: clamp(2.5rem, 5vw, 4rem);
      padding-block: clamp(2.5rem, 6vw, 4rem) clamp(4rem, 9vw, 6rem);
    }

    .hero__media {
      margin-inline: 0;
      max-width: none;
      width: 100%;
      height: 100%;
      min-height: 0;
      aspect-ratio: auto;
      align-self: stretch;
    }

    .hero__copy {
      min-height: 100%;
    }
  }
</style>
