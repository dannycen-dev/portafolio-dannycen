---
import { site } from "../data/site";
---

<section class="hero container" data-hero>
  <div class="hero__media" data-hero-image>
    <div class="hero__portrait" aria-hidden="true">
      <svg viewBox="0 0 640 800" xmlns="http://www.w3.org/2000/svg" role="img">
        <defs>
          <linearGradient id="sky" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#1b6b63" />
            <stop offset="55%" stop-color="#0f4a45" />
            <stop offset="100%" stop-color="#2f4a3c" />
          </linearGradient>
          <radialGradient id="glow" cx="50%" cy="35%" r="55%">
            <stop offset="0%" stop-color="#c8a45c" stop-opacity="0.35" />
            <stop offset="100%" stop-color="#c8a45c" stop-opacity="0" />
          </radialGradient>
        </defs>
        <rect width="640" height="800" fill="url(#sky)" />
        <rect width="640" height="800" fill="url(#glow)" />
        <circle cx="320" cy="290" r="96" fill="#d5e8e5" opacity="0.9" />
        <path
          d="M170 760c30-150 90-230 150-230s120 80 150 230"
          fill="#d5e8e5"
          opacity="0.88"
        />
        <text
          x="320"
          y="560"
          text-anchor="middle"
          fill="#eef1ef"
          font-family="Syne, sans-serif"
          font-size="42"
          font-weight="700"
          letter-spacing="-1"
        >
          DC
        </text>
      </svg>
    </div>
    <p class="hero__photo-note">Reemplaza con tu foto profesional</p>
  </div>

  <div class="hero__copy">
    <p class="hero__eyebrow" data-hero-anim>{site.location}</p>
    <h1 data-hero-anim>
      Soy <span>{site.name.split(" ")[0]}</span>, desarrollador web y especialista
      en automatización e IA.
    </h1>
    <p class="hero__lead" data-hero-anim>
      {site.shortBio}
      <a href="/about">Conoce más sobre mí</a>.
    </p>
    <div class="hero__actions" data-hero-anim>
      <a class="btn" href="/contact">Trabajemos juntos</a>
      <a class="btn btn--ghost" href="/projects">Ver proyectos</a>
    </div>
    <div class="hero__social" data-hero-anim>
      <a href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={`mailto:${site.email}`}>Email</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: clamp(2rem, 5vw, 3.5rem) clamp(3rem, 8vw, 5rem);
  }

  .hero__media {
    position: relative;
    overflow: hidden;
    background: #0f4a45;
    aspect-ratio: 4 / 5;
    max-width: 28rem;
    margin-inline: auto;
    width: 100%;
  }

  .hero__portrait {
    width: 100%;
    height: 100%;
  }

  .hero__portrait svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__photo-note {
    position: absolute;
    left: 0.75rem;
    bottom: 0.75rem;
    padding: 0.35rem 0.55rem;
    background: rgba(18, 22, 20, 0.55);
    color: #f4f6f4;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .hero__eyebrow {
    margin-bottom: 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero h1 {
    font-size: clamp(2.35rem, 1.4rem + 3.4vw, 4rem);
    max-width: 14ch;
  }

  .hero h1 span {
    color: var(--accent);
  }

  .hero__lead {
    margin-top: 1.25rem;
    max-width: 42ch;
    color: var(--ink-soft);
  }

  .hero__lead a {
    font-weight: 600;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .hero__social {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.75rem;
    font-size: 0.95rem;
  }

  .hero__social a {
    text-decoration: none;
    font-weight: 600;
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(16rem, 22rem) minmax(0, 1fr);
      align-items: end;
      gap: clamp(2.5rem, 6vw, 5rem);
      padding-block: clamp(2.5rem, 6vw, 4rem) clamp(4rem, 9vw, 6rem);
    }

    .hero__media {
      margin-inline: 0;
      max-width: none;
    }
  }
</style>
