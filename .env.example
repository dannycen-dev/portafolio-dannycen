// Secrets go in `.dev.vars` (local) or `wrangler secret put` (production).
// Never commit real keys.

# Public site
PUBLIC_SITE_URL=https://dannydev.space

# Booking defaults (also mirrored in wrangler.jsonc vars)
BOOKING_TIMEZONE=America/Merida
BOOKING_SLOTS=09:00,10:00,11:30,14:00,15:30,17:00
BOOKING_DURATION_MIN=30
NOTIFY_TO_EMAIL=dannycen.dev@gmail.com
GOOGLE_CALENDAR_ID=primary

# ─── Google Cloud OAuth (Calendar + Gmail) ─────────────────────────────
# 1) GCP Console → APIs & Services → enable:
#      - Google Calendar API
#      - Gmail API
# 2) Create OAuth client (Desktop app or Web) under Credentials.
# 3) Run the one-time OAuth consent flow to get a refresh token for the
#    Google account that owns the calendar/inbox (dannycen.dev@gmail.com).
#    Helper: https://developers.google.com/oauthplayground
#    Scopes needed:
#      https://www.googleapis.com/auth/calendar
#      https://www.googleapis.com/auth/gmail.send
# 4) Put values below (and also as Wrangler secrets in production).

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional later: Cloudflare Turnstile
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
