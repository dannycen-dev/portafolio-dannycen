{
  "name": "dannydev-portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4329",
    "build": "astro build && node scripts/prepare-pages.mjs",
    "preview": "astro preview --host 127.0.0.1 --port 4329",
    "astro": "astro",
    "deploy": "npm run build && wrangler deploy",
    "cf:types": "wrangler types",
    "db:create": "wrangler d1 create dannydev-contact",
    "db:migrate:local": "wrangler d1 migrations apply dannydev-contact --local",
    "db:migrate": "wrangler d1 migrations apply dannydev-contact --remote",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:only": "playwright test"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.9",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "wrangler": "^4.110.0"
  }
}
